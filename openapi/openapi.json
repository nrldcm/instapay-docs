    "/payments": {
      "post": {
        "operationId": "PaymentsController_originate",
        "summary": "Originate an outbound credit transfer",
        "description": "Builds a signed pacs.008 from the request, submits it to the CI, and returns the resolved outcome (matched pacs.002), a timeout, or a submit rejection.",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OriginatePaymentDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentResultDto"
                }
              }
            }
          }
        },
        "tags": [
          "Payments (Our app → InstaPay)"
        ]
      },
      "get": {
        "operationId": "PaymentsController_list",
        "summary": "List transactions (JSON) — reconciliation feed",
        "description": "Returns the JSON transaction journal (inbound + outbound). A counterpart service can poll this (e.g. by a cron with ?since=) to independently verify/reconcile transactions. No XML is ever exposed — only readable JSON.",
        "parameters": [
          {
            "name": "since",
            "required": false,
            "in": "query",
            "description": "ISO timestamp — records updated at/after this (the cron passes its last-run time).",
            "schema": {
              "example": "2026-07-16T00:00:00Z",
              "type": "string"
            }
          },
          {
            "name": "status",
            "required": false,
            "in": "query",
            "schema": {
              "enum": [
                "PENDING",
                "RECEIVED",
                "COMPLETED",
                "FAILED",
                "TIMED_OUT",
                "REVERSED"
              ],
              "type": "string"
            }
          },
          {
            "name": "direction",
            "required": false,
            "in": "query",
            "schema": {
              "enum": [
                "OUTBOUND",
                "INBOUND"
              ],
              "type": "string"
            }
          },
          {
            "name": "limit",
            "required": false,
            "in": "query",
            "schema": {
              "example": 100,
              "type": "number"
            }
          },
          {
            "name": "offset",
            "required": false,
            "in": "query",
            "schema": {
              "example": 0,
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "tags": [
          "Payments (Our app → InstaPay)"
        ]
      }
    },
    "/payments/in-flight": {
      "get": {
        "operationId": "PaymentsController_inFlight",
        "summary": "Diagnostics: count of in-flight and recently received transactions",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "tags": [
          "Payments (Our app → InstaPay)"
        ]
      }
    },
    "/payments/{instructionId}": {
      "get": {
        "operationId": "PaymentsController_getOne",
        "summary": "Get one transaction by Instruction Id (JSON)",
        "description": "Readable JSON status of a single transaction. Used for status checks/verification.",
        "parameters": [
          {
            "name": "instructionId",
            "required": true,
            "in": "path",
            "description": "The PmtId/InstrId of the transaction.",
            "schema": {
              "example": "INSTR8f2c1a4b9d",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The transaction record."
          },
          "404": {
            "description": "No transaction with that Instruction Id."
          }
        },
        "tags": [
          "Payments (Our app → InstaPay)"
        ]
      }
    },
    "/audit": {
      "get": {
        "operationId": "LedgerController_audit",
        "summary": "Audit trail (JSON) — verify what came in / was posted",
        "description": "Every money event and delivery attempt: RECEIVED, ENQUEUED, DELIVERY_ATTEMPT, DELIVERY_OK, DELIVERY_FAILED, DEAD_LETTER. Filter by instructionId, action, since.",
        "parameters": [
          {
            "name": "instructionId",
            "required": false,
            "in": "query",
            "schema": {
              "example": "INSTR8f2c1a4b9d",
              "type": "string"
            }
          },
          {
            "name": "action",
            "required": false,
            "in": "query",
            "schema": {
              "enum": [
                "RECEIVED",
                "ENQUEUED",
                "DELIVERY_ATTEMPT",
                "DELIVERY_OK",
                "DELIVERY_FAILED",
                "DEAD_LETTER"
              ],
              "type": "string"
            }
          },
          {
            "name": "since",
            "required": false,
            "in": "query",
            "description": "ISO timestamp",
            "schema": {
              "example": "2026-07-16T00:00:00Z",
              "type": "string"
            }
          },
          {
            "name": "limit",
            "required": false,
            "in": "query",
            "schema": {
              "example": 200,
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "tags": [
          "Ledger & Audit"
        ]
      }
    },
    "/ledger/outbox": {
      "get": {
        "operationId": "LedgerController_outbox",
        "summary": "Outbox status (JSON) — pending / dead-lettered deliveries",
        "description": "Durable outbox of money events awaiting or failed delivery to the ledger.",
        "parameters": [
          {
            "name": "status",
            "required": false,
            "in": "query",
            "schema": {
              "enum": [
                "PENDING",
                "DELIVERED",
                "DEAD"
              ],
              "type": "string"
            }
          },
          {
            "name": "limit",
            "required": false,
            "in": "query",
            "schema": {
              "example": 100,
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "tags": [
          "Ledger & Audit"
        ]
      }
    },
    "/logs": {
      "get": {
        "operationId": "LogsController_query",
        "summary": "Query persisted logs (JSON)",
        "description": "Fast, indexed query over the partitioned log table. Filters map to indexed columns: from/to (ts), level, instructionId, correlationId, bizMsgIdr. Requires LOG_DB_ENABLED=true.",
        "parameters": [
          {
            "name": "from",
            "required": false,
            "in": "query",
            "description": "ISO timestamp (inclusive).",
            "schema": {
              "example": "2026-07-16T00:00:00Z",
              "type": "string"
            }
          },
          {
            "name": "to",
            "required": false,
            "in": "query",
            "description": "ISO timestamp (inclusive).",
            "schema": {
              "example": "2026-07-16T23:59:59Z",
              "type": "string"
            }
          },
          {
            "name": "level",
            "required": false,
            "in": "query",
            "schema": {
              "enum": [
                "error",
                "warn",
                "info",
                "debug",
                "verbose"
              ],
              "type": "string"
            }
          },
          {
            "name": "instructionId",
            "required": false,
            "in": "query",
            "schema": {
              "example": "INSTR8f2c1a4b9d",
              "type": "string"
            }
          },
          {
            "name": "correlationId",
            "required": false,
            "in": "query",
            "schema": {
              "example": "c0ffee-1234",
              "type": "string"
            }
          },
          {
            "name": "bizMsgIdr",
            "required": false,
            "in": "query",
            "schema": {
              "example": "MSG-CT-0001",
              "type": "string"
            }
          },
          {
            "name": "limit",
            "required": false,
            "in": "query",
            "schema": {
              "example": 100,
              "type": "number"
            }
          },
          {
            "name": "offset",
            "required": false,
            "in": "query",
            "schema": {
              "example": 0,
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "tags": [
          "Logs"
        ]
      }
    }
  },
  "info": {
    "title": "InstaPay ISO 20022 Integration Service",
    "description": "BancNet / Mastercard IPS participant integration (originator + receiver). Exposes the CI-facing ISO 20022 endpoints and an internal JSON API to originate payments.",
    "version": "0.1.0",
    "contact": {}
  },
  "tags": [
    {
      "name": "IPS Payments (CI → Participant)",
      "description": "Endpoints the Central Infrastructure calls on us"
    },
    {
      "name": "Payments (Our app → InstaPay)",
      "description": "Internal API to originate outbound credit transfers"
    }
  ],
  "servers": [],
  "components": {
    "schemas": {
      "DebtorDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Juan Dela Cruz",
            "description": "Payer full name."
          },
          "id": {
            "type": "string",
            "example": "DBTR001",
            "description": "Payer identifier (person id)."
          },
          "account": {
            "type": "string",
            "example": "00123456789",
            "description": "Payer account number."
          },
          "accountType": {
            "type": "string",
            "example": "CASH",
            "description": "Account type proprietary code."
          }
        },
        "required": [
          "name",
          "id",
          "account"
        ]
      },
      "CreditorDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Maria Santos",
            "description": "Payee full name."
          },
          "id": {
            "type": "string",
            "example": "CDTR001",
            "description": "Payee identifier (person id)."
          },
          "account": {
            "type": "string",
            "example": "00987654321",
            "description": "Payee account number."
          },
          "agentBic": {
            "type": "string",
            "example": "BDOMPHMMXXX",
            "description": "Payee bank BICFI (creditor agent)."
          }
        },
        "required": [
          "name",
          "id",
          "account",
          "agentBic"
        ]
      },
      "OriginatePaymentDto": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "string",
            "example": "1500.00",
            "description": "Amount as a decimal string."
          },
          "currency": {
            "type": "string",
            "example": "PHP",
            "description": "ISO 4217 currency code."
          },
          "debtor": {
            "$ref": "#/components/schemas/DebtorDto"
          },
          "creditor": {
            "$ref": "#/components/schemas/CreditorDto"
          },
          "remittanceInfo": {
            "type": "string",
            "example": "Payment for invoice 123",
            "description": "Unstructured remittance text."
          },
          "endToEndId": {
            "type": "string",
            "example": "E2E-0001",
            "description": "Caller-supplied end-to-end id; generated if omitted."
          }
        },
        "required": [
          "amount",
          "currency",
          "debtor",
          "creditor"
        ]
      },
      "PaymentResultDto": {
        "type": "object",
        "properties": {
          "instructionId": {
            "type": "string",
            "example": "INSTR8f2c..."
          },
          "endToEndId": {
            "type": "string",
            "example": "E2E-0001"
          },
          "transactionId": {
            "type": "string",
            "example": "TX3a91..."
          },
          "state": {
            "type": "string",
            "example": "COMPLETED",
            "enum": [
              "COMPLETED",
              "FAILED",
              "TIMED_OUT",
              "REJECTED_AT_SUBMIT"
            ],
            "description": "Final outcome of the originated payment."
          },
          "status": {
            "type": "string",
            "example": "ACSC",
            "description": "ISO transaction status when resolved."
          },
          "reasonCode": {
            "type": "string",
            "example": "AC01",
            "description": "Reason code on rejection."
          },
          "submissions": {
            "type": "number",
            "example": 1,
            "description": "Number of submissions incl. duplicate resubmissions."
          }
        },
        "required": [
          "instructionId",
          "endToEndId",
          "transactionId",
          "state",
          "submissions"
        ]
      }
    }
  }
}